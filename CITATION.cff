license: MIT
repository-code: "https://github.com/Tahsin2799/ncdvi-hypertension-bangladesh"
keywords:
  - hypertension
  - non-communicable diseases
  - vulnerability index
  - multiple correspondence analysis
  - multilevel logistic regression
  - Bangladesh
  - BDHS
  - external validation
