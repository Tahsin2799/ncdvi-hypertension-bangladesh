@article{bacon_effects_2004,
	title = {Effects of {Exercise}, {Diet} and {Weight} {Loss} on {High} {Blood} {Pressure}},
	volume = {34},
	issn = {1179-2035},
	url = {https://doi.org/10.2165/00007256-200434050-00003},
	doi = {10.2165/00007256-200434050-00003},
	abstract = {High blood pressure (BP) is a major health problem in the US, affecting more than 50 million people. Although high BP is among the most common reasons for outpatient visits, BP control is often inadequate. It is well established that BP can be lowered pharmacologically in hypertensive individuals; however, anti-hypertensive medications are not effective for everyone, and may be costly and result in adverse effects that impair quality of life and reduce adherence. Moreover, abnormalities associated with high BP, such as insulin resistance and hyper-lipidaemia, may persist or may even be exacerbated by some anti-hypertensive medications. Consequently, there has been a great deal of interest in the development and application of behavioural interventions in the management of high BP.},
	language = {en},
	number = {5},
	urldate = {2024-10-05},
	journal = {Sports Medicine},
	author = {Bacon, Simon L. and Sherwood, Andrew and Hinderliter, Alan and Blumenthal, James A.},
	month = apr,
	year = {2004},
	keywords = {Arterial Stiffness, Diastolic Blood Pressure, High Blood Pressure, Leave Ventricular Hypertrophy, Systolic Blood Pressure},
	pages = {307--316},
	file = {Full Text PDF:C\:\\Users\\ASUS\\Zotero\\storage\\SN4UMH8L\\Bacon et al. - 2004 - Effects of Exercise, Diet and Weight Loss on High Blood Pressure.pdf:application/pdf},
}

